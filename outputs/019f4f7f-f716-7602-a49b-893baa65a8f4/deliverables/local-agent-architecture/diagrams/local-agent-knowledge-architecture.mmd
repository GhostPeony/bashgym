graph TB
  U["Person"]

  subgraph PC["Home workstation and conversation surfaces"]
    direction LR
    CANVAS["Visual AI / ML canvas"]
    CODEX["Coding-agent sessions"]
    TUNNEL["Managed SSH port-forward"]
    CHAT["Messaging channel"]
    VOICE["Voice client"]
  end

  subgraph HOST["Local agent host"]
    direction LR
    ENTRY["Authenticated gateway + text bridge"]
    AGENT["Hermes agent runtime"]
    MODELS["Local chat + dense models"]
    BRAIN["GBrain knowledge service"]
    ARTIFACTS["Training runs + reports"]
    MOUNT["Desktop session mount<br/>(explicit reads only)"]
  end

  GIT["Private Git repository"]

  U --> CANVAS
  U --> CODEX
  U --> CHAT
  U --> VOICE
  CANVAS -->|"sanitized workspace context"| TUNNEL
  TUNNEL -->|"localhost API over SSH"| ENTRY
  CHAT -->|"gateway message"| ENTRY
  VOICE -->|"transcribed text"| ENTRY
  ENTRY -->|"source-scoped session"| AGENT
  AGENT -->|"inference"| MODELS
  AGENT -->|"explicit scoped retrieval"| BRAIN
  AGENT -->|"observe / run / evaluate"| ARTIFACTS
  ARTIFACTS -->|"curated milestones"| BRAIN
  CODEX -. "session journals via separate SSHFS lane" .-> MOUNT
  MOUNT -. "available when explicitly inspected" .-> AGENT
  BRAIN -->|"commit + push"| GIT
  GIT -->|"scheduled pull / recovery"| BRAIN

  classDef person fill:#E9878C,stroke:#25233B,stroke-width:3px,color:#25233B;
  classDef workstation fill:#FFF8EF,stroke:#25233B,stroke-width:2px,color:#25233B;
  classDef host fill:#F0E8D8,stroke:#25233B,stroke-width:2px,color:#25233B;
  classDef durable fill:#DDE8D3,stroke:#25233B,stroke-width:3px,color:#25233B;
  class U person;
  class CANVAS,CODEX,TUNNEL,CHAT,VOICE workstation;
  class ENTRY,AGENT,MODELS,ARTIFACTS,MOUNT host;
  class BRAIN,GIT durable;
