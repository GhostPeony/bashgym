graph TD
  Q["Operational question"] --> LIVE["1. Live jobs, manifests, and evaluator output"]
  LIVE --> CURATED["2. Scoped GBrain receipts"]
  CURATED --> HANDOFF["3. Sanitized Codex handoffs (planned)"]
  HANDOFF --> HISTORY["4. Historical context"]
  HISTORY --> RECONCILE["Reconcile conflicts + display provenance"]
  RECONCILE --> ANSWER["Answer, recommendation, or guarded action"]

  STALE["Dated skill text"] -. "never authoritative for current state" .-> RECONCILE

  classDef question fill:#E9878C,stroke:#25233B,stroke-width:3px,color:#25233B;
  classDef source fill:#FFF8EF,stroke:#25233B,stroke-width:2px,color:#25233B;
  classDef durable fill:#DDE8D3,stroke:#25233B,stroke-width:2px,color:#25233B;
  classDef decision fill:#F0E8D8,stroke:#25233B,stroke-width:3px,color:#25233B;
  classDef stale fill:#F7E9B6,stroke:#7A5A00,stroke-width:2px,stroke-dasharray: 5 4,color:#25233B;
  class Q question;
  class LIVE,CURATED,HANDOFF source;
  class HISTORY durable;
  class RECONCILE,ANSWER decision;
  class STALE stale;
