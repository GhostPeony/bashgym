{
  "name": "bash-gym",
  "version": "1.0.0",
  "description": "Bash Gym - Self-Improving Training Workspace",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently --kill-others --success first --names renderer,desktop \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:smoke:packaged": "node scripts/packaged-electron-smoke.mjs",
    "web:dev": "vite --config vite.config.web.ts --mode web",
    "web:build": "vite build --config vite.config.web.ts --mode web",
    "test": "node scripts/run-tests.mjs",
    "lint": "eslint src electron scripts --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "node scripts/format-tracked-files.mjs",
    "format:check": "node scripts/format-tracked-files.mjs --check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@neondatabase/serverless": "^1.0.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.10.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.1",
    "v0-sdk": "^0.16.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "26.15.3",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "playwright-core": "1.61.1",
    "prettier": "^3.5.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.bashgym.app",
    "productName": "Bash Gym",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": "AppImage"
    }
  }
}
