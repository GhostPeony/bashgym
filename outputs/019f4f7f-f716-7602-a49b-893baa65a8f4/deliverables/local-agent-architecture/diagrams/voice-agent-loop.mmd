graph LR
  MIC["Microphone"] --> WAKE["Wake word + endpointing"]
  WAKE --> STT["Speech-to-text"]
  STT --> CLIENT["Voice client"]
  CLIENT -->|"text request"| BRIDGE["LAN text bridge"]
  BRIDGE -->|"resume source session"| AGENT["Hermes runtime"]

  subgraph REASONING["Agent host"]
    AGENT --> MODEL["Local language model"]
    AGENT -->|"optional / explicit"| BRAIN["Scoped GBrain retrieval"]
    AGENT --> TOOLS["Approved tools + workflows"]
  end

  AGENT -->|"response text"| BRIDGE
  BRIDGE --> CLIENT
  CLIENT --> TTS["Text-to-speech"]
  TTS --> SPEAKER["Speaker"]

  STT -. "known home command" .-> ROUTER["Deterministic home router<br/>(planned / separate lane)"]
  ROUTER -.-> SPEAKER

  classDef input fill:#FFF8EF,stroke:#25233B,stroke-width:2px,color:#25233B;
  classDef bridge fill:#F0E8D8,stroke:#25233B,stroke-width:3px,color:#25233B;
  classDef agent fill:#E9878C,stroke:#25233B,stroke-width:3px,color:#25233B;
  classDef knowledge fill:#DDE8D3,stroke:#25233B,stroke-width:2px,color:#25233B;
  classDef planned fill:#F7E9B6,stroke:#7A5A00,stroke-width:2px,stroke-dasharray: 5 4,color:#25233B;
  class MIC,WAKE,STT,CLIENT,TTS,SPEAKER input;
  class BRIDGE bridge;
  class AGENT agent;
  class MODEL,BRAIN,TOOLS knowledge;
  class ROUTER planned;
